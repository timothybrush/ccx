# 环境变量示例配置
# 复制此文件为 .env 并修改配置

# ============ 服务器配置 ============
PORT=3688

# 运行环境: development | production
# 影响:
#   - production: Gin ReleaseMode(高性能)、关闭/admin/dev/info、严格CORS
#   - development: Gin DebugMode(详细日志)、开启/admin/dev/info、宽松CORS
# 生产环境务必设置为 production！
ENV=production

# ============ Web UI 配置 ============
# 是否启用 Web 管理界面
ENABLE_WEB_UI=true
# Web UI 默认语言: en | id | zh-CN
APP_UI_LANGUAGE=zh-CN

# ============ 访问控制 ============
# 代理访问密钥（必须修改！）
PROXY_ACCESS_KEY=your-proxy-access-key
# 额外代理访问密钥（可选，逗号分隔；仅用于代理 API，不授予管理权限）
# 启用后必须设置独立 ADMIN_ACCESS_KEY，且不能与任何代理密钥相同
# EXTRA_PROXY_ACCESS_KEYS=extra-proxy-key-1,extra-proxy-key-2
# 管理 API 独立密钥（可选，未设置时回退到 PROXY_ACCESS_KEY）
# 设置 EXTRA_PROXY_ACCESS_KEYS 后必须显式设置，用于管理界面和 /api/* 端点认证
# ADMIN_ACCESS_KEY=your-admin-access-key-here

# ============ 日志配置 ============
# 日志级别: error | warn | info | debug
LOG_LEVEL=info

# 是否启用请求/响应日志
# 注意：默认值为 true，注释掉此项等于启用日志
# 要禁用日志必须显式设置为 false，不能通过注释来禁用
ENABLE_REQUEST_LOGS=false
ENABLE_RESPONSE_LOGS=false

# 静默前端轮询端点日志（调试时避免刷屏）
QUIET_POLLING_LOGS=true

# 原始日志输出（不缩进、不截断、不重排序，直接输出完整请求/响应内容）
RAW_LOG_OUTPUT=false

# --- 内置日志文件自动轮转配置（可选，以下为默认值说明） ---
# LOG_DIR=logs                           # 自定义日志存储目录 (默认 logs，可被 --logdir 覆盖)
# LOG_DIR=none                           # 禁用日志文件写入，仅输出到控制台 (none/null 均可，不区分大小写)
# LOG_FILE=app.log                       # 自定义日志文件名 (默认 app.log)
# LOG_MAX_SIZE=100                       # 单个日志文件最大切分大小 (MB) (默认 100)
# LOG_MAX_BACKUPS=10                     # 最多保留的切分旧日志文件个数 (默认 10)
# LOG_MAX_AGE=30                         # 旧日志文件最大保留天数 (默认 30)
# LOG_COMPRESS=true                      # 是否对切分出的历史旧日志进行 gzip 压缩 (默认 true)
# LOG_TO_CONSOLE=true                    # 是否在写入日志文件的同时输出到控制台 (默认 true)

# SSE 调试级别: off | summary | full
# full: 记录每个 SSE 事件的类型、长度、content_block 详情
# summary: 仅在流结束时记录事件统计摘要
# off: 关闭 SSE 调试日志（默认）
SSE_DEBUG_LEVEL=off

# 是否改写响应中的 model 字段为请求的 model（默认 false）
# 启用后，当上游返回的 model 与请求的 model 不一致时，会自动改写为请求的 model
# 注意：影响 Messages API（流式）和 Responses API（流式 + 非流式），不影响 Gemini API
REWRITE_RESPONSE_MODEL=false

# ============ 性能配置 ============
# HTTP 服务端读取入站请求超时（毫秒），仅影响客户端到代理的读超时
# 默认 60000（1 分钟），与上游请求超时解耦
SERVER_READ_TIMEOUT=60000

# 请求体最大大小（MB），默认 50
MAX_REQUEST_BODY_SIZE_MB=50

# 以下上游请求生命周期参数仅作为启动兜底/旧部署兼容项。
# 运行时请优先使用 Web/桌面调校台，保存后会写入 config.json 的 circuitBreaker 并热生效。
# REQUEST_TIMEOUT=120000                 # 非流式上游请求总超时（毫秒，1000-300000）
# RESPONSE_HEADER_TIMEOUT=60             # 等待上游 HTTP 响应头超时（秒，30-120；调校台支持到 300 秒）

# ============ CORS 配置 ============
ENABLE_CORS=false
CORS_ORIGIN=*

# ============ 熔断指标启动兜底（旧部署兼容） ============
# 运行时请优先使用 Web/桌面调校台。
# METRICS_WINDOW_SIZE=10                 # 滑动窗口大小（最小 3，默认 10）
# METRICS_FAILURE_THRESHOLD=0.5          # 失败率阈值（0-1，默认 0.5 即 50%）

# ============ 指标持久化配置 ============
# 是否启用 SQLite 持久化（默认 true）
# 启用后重启服务不会丢失历史指标数据
METRICS_PERSISTENCE_ENABLED=true
# 数据保留天数（3-366，默认 366）
# 支持查询最长 1 年的历史数据
METRICS_RETENTION_DAYS=366

# ============ 驾驶舱配置 ============
# 驾驶舱自定义渠道排序（override）默认有效期（分钟，1-1440，默认 30）
# 设为较大值可延长 override 有效期；支持在驾驶舱 UI 中按次选择不同有效期
# OVERRIDE_TTL_MINUTES=30
